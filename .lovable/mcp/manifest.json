          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "limit": {
              "description": "Max rows (default 50).",
              "type": "integer",
              "minimum": 1,
              "maximum": 200
            }
          }
        },
        "outputSchema": null
      },
      {
        "name": "create_project",
        "title": "Create project",
        "description": "Create a new project for the signed-in user.",
        "annotations": {
          "readOnlyHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "name": {
              "type": "string",
              "minLength": 1,
              "description": "Project name."
            },
            "description": {
              "type": "string"
            },
            "parent_id": {
              "description": "Parent project id — creates a subproject under it. Omit for a top-level project.",
              "anyOf": [
                {
                  "type": "string",
                  "format": "uuid",
                  "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$"
                },
                {
                  "type": "null"
                }
              ]
            },
            "parent_path": {
              "description": "Alternative to parent_id: '/'-separated path to the parent project; missing nodes are auto-created.",
              "type": "string"
            }
          },
          "required": [
            "name"
          ]
        },
        "outputSchema": null
      },
