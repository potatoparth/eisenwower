      {
        "name": "create_note",
        "title": "Create note",
        "description": "Create a note. Notes can live inside a project (including shared projects the user can edit) and be assigned to a collaborator.",
        "annotations": {
          "readOnlyHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "title": {
              "type": "string",
              "minLength": 1,
              "description": "Note title."
            },
            "content": {
              "description": "Markdown / plain text body.",
              "type": "string"
            },
            "project_id": {
              "description": "Attach to a specific project id.",
              "type": "string",
              "format": "uuid",
              "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$"
            },
            "project_path": {
              "description": "Alternative to project_id: '/'-separated project path; missing nodes are created.",
              "type": "string"
            },
            "pinned": {
              "description": "Pin to the top.",
              "type": "boolean"
            },
            "assigned_to": {
              "description": "Assign the note to a user id (owner or collaborator on the project). Defaults to the caller.",
              "type": "string",
              "format": "uuid",
              "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$"
            }
          },
