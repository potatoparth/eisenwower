{
  "version": 1,
  "sdk_version": "0.20.0",
  "path": "/functions/v1/mcp",
  "auth": {
    "type": "oauth",
    "issuer": "https://bvhwblwojecapnxivqnl.supabase.co/auth/v1",
    "accepted_audiences": [
      "authenticated"
