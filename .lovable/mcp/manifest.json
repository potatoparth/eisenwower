  "mcp": {
    "server": {
      "name": "weizen-mcp",
      "version": "0.1.0",
      "title": "Weizen"
    },
    "tools": [
      {
        "name": "list_tasks",
        "title": "List tasks",
        "description": "List Eisenhower Matrix tasks the signed-in user owns or has access to via shared projects. Filter by status, quadrant, project, assignee, or archived state. Results include authorship metadata (created_by, updated_by, assigned_to) and archived_at.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "status": {
              "description": "Filter by status.",
              "type": "string",
              "enum": [
                "open",
                "done"
              ]
            },
            "quadrant": {
              "description": "Filter by Eisenhower quadrant.",
              "type": "string",
              "enum": [
                "important-urgent",
                "important-not-urgent",
                "not-important-urgent",
                "not-important-not-urgent"
              ]
            },
            "project_id": {
              "description": "Filter to tasks under this project id (includes tasks on all descendant subprojects).",
              "type": "string",
              "format": "uuid",
              "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$"
            },
            "project_path": {
              "description": "Alternative to project_id: '/'-separated project path.",
              "type": "string"
            },
            "assigned_to": {
              "description": "Filter to tasks assigned to this user id.",
              "type": "string",
              "format": "uuid",
              "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$"
            },
            "include_archived": {
              "description": "Include archived (completed & recycled) tasks. Default false — archived tasks are hidden.",
              "type": "boolean"
            },
            "only_archived": {
              "description": "Return ONLY archived tasks (archived_at is not null).",
              "type": "boolean"
            },
            "limit": {
              "description": "Max rows (default 50).",
              "type": "integer",
              "minimum": 1,
              "maximum": 200
            }
          }
        },
        "outputSchema": null
      },
      {
        "name": "create_task",
        "title": "Create task",
        "description": "Create a task in a specific Eisenhower quadrant. Supports description, project association (own or shared projects), status, attachments, and assigning to a collaborator on a shared project.",
        "annotations": {
          "readOnlyHint": false,
          "destructiveHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "name": {
              "type": "string",
              "minLength": 1,
              "description": "Task name."
            },
            "description": {
              "description": "Optional longer description.",
              "type": "string"
            },
            "quadrant": {
              "type": "string",
              "enum": [
                "important-urgent",
                "important-not-urgent",
                "not-important-urgent",
                "not-important-not-urgent"
              ],
              "description": "Eisenhower quadrant."
            },
            "due_date": {
              "description": "Due date YYYY-MM-DD.",
              "type": "string"
            },
            "due_time": {
              "description": "Due time HH:MM (24h).",
              "type": "string"
            },
            "project_id": {
              "description": "Associate the task with a specific project id (project_templates.id). Projects are hierarchical — a project's parent_id makes it a subproject.",
              "type": "string",
              "format": "uuid",
              "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$"
            },
            "project_path": {
              "description": "Alternative to project_id: '/'-separated project path like 'Work/Q4/Launch'. Any missing intermediate projects are auto-created for the user.",
              "type": "string"
            },
            "status": {
              "description": "Initial status (default 'open').",
              "type": "string",
              "enum": [
                "open",
                "done"
              ]
            },
            "assigned_to": {
              "description": "User id to assign this task to (must be the owner or a collaborator on the task's project). Defaults to the caller.",
              "type": "string",
              "format": "uuid",
              "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$"
            },
            "attachments": {
              "description": "Attachments to add. Use kind='link' with a URL, or kind='file' with an existing storage path in the task-attachments bucket.",
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "id": {
                    "description": "Stable id; auto-generated if omitted.",
                    "type": "string"
                  },
                  "name": {
                    "type": "string",
                    "minLength": 1,
                    "description": "Display label."
                  },
                  "kind": {
                    "type": "string",
                    "enum": [
                      "file",
                      "link"
                    ],
                    "description": "'link' for URLs, 'file' for objects already in the task-attachments bucket."
                  },
                  "path": {
                    "type": "string",
                    "minLength": 1,
                    "description": "For links: full URL. For files: storage object path inside the task-attachments bucket."
                  },
                  "size": {
                    "type": "integer",
                    "minimum": 0,
                    "maximum": 9007199254740991
                  },
                  "contentType": {
                    "type": "string"
                  },
                  "addedAt": {
                    "type": "string"
                  }
                },
                "required": [
                  "name",
                  "kind",
                  "path"
                ]
              }
            }
          },
          "required": [
            "name",
            "quadrant"
          ]
        },
        "outputSchema": null
      },
      {
        "name": "update_task",
        "title": "Update task",
        "description": "Update fields on an existing task: name, description, quadrant (move between Eisenhower quadrants), category, due date/time (reschedule), status (mark done/reopen), project association, or attachments. Cannot change task ownership.",
        "annotations": {
          "readOnlyHint": false,
          "idempotentHint": true
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "task_id": {
              "type": "string",
              "format": "uuid",
              "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$",
              "description": "Task id."
            },
            "name": {
              "type": "string",
              "minLength": 1
            },
            "description": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ]
            },
            "quadrant": {
              "description": "Move task to a different Eisenhower quadrant.",
              "type": "string",
              "enum": [
                "important-urgent",
                "important-not-urgent",
                "not-important-urgent",
                "not-important-not-urgent"
              ]
            },
            "due_date": {
              "description": "YYYY-MM-DD, or null to clear.",
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ]
            },
            "due_time": {
              "description": "HH:MM (24h), or null to clear.",
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ]
            },
            "status": {
              "description": "Set to 'done' to complete, 'open' to reopen.",
              "type": "string",
              "enum": [
                "open",
                "done"
              ]
            },
            "project_id": {
              "description": "Associate with a project, or null to detach.",
              "anyOf": [
                {
                  "type": "string",
                  "format": "uuid",
                  "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$"
                },
                {
                  "type": "null"
                }
              ]
            },
            "project_path": {
              "description": "Alternative to project_id: '/'-separated project path; missing nodes are created.",
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ]
            },
            "assigned_to": {
              "description": "Reassign the task to a user id (owner or collaborator on the project), or null to unassign.",
              "anyOf": [
                {
                  "type": "string",
                  "format": "uuid",
                  "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$"
                },
                {
                  "type": "null"
                }
              ]
            },
            "attachments": {
              "description": "Attachments to add or replace. Use kind='link' with URL, or kind='file' with an existing storage path.",
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "id": {
                    "description": "Stable id; auto-generated if omitted.",
                    "type": "string"
                  },
                  "name": {
                    "type": "string",
                    "minLength": 1,
                    "description": "Display label."
                  },
                  "kind": {
                    "type": "string",
                    "enum": [
                      "file",
                      "link"
                    ],
                    "description": "'link' for URLs, 'file' for objects already in the task-attachments bucket."
                  },
                  "path": {
                    "type": "string",
                    "minLength": 1,
                    "description": "For links: full URL. For files: storage object path inside the task-attachments bucket."
                  },
                  "size": {
                    "type": "integer",
                    "minimum": 0,
                    "maximum": 9007199254740991
                  },
                  "contentType": {
                    "type": "string"
                  },
                  "addedAt": {
                    "type": "string"
                  }
                },
                "required": [
                  "name",
                  "kind",
                  "path"
                ]
              }
            },
            "attachments_mode": {
              "description": "How to apply `attachments`: 'append' (default) adds to existing, 'replace' overwrites the full list.",
              "type": "string",
              "enum": [
                "append",
                "replace"
              ]
            }
          },
          "required": [
            "task_id"
          ]
        },
        "outputSchema": null
      },
      {
        "name": "complete_task",
        "title": "Complete task",
        "description": "Mark a task as done (or reopen it).",
